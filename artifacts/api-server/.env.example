# Database
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Auth
JWT_SECRET=your-super-secret-jwt-key

# CORS (comma-separated if needed)
CORS_ORIGIN=https://your-frontend.vercel.app
CORS_ORIGIN_2=https://your-other-frontend-url.vercel.app

# Plaid
PLAID_CLIENT_ID=your-plaid-client-id
PLAID_SECRET=your-plaid-secret
PLAID_ENV=sandbox  # sandbox | development | production

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Email (Resend) — set on the API service in production
# RESEND_API_KEY=re_...
# EMAIL_FROM must be an address on a domain verified in your Resend account (not optional for real recipients).
# EMAIL_FROM="MissionLedger <noreply@yourdomain.com>"
# Public site URL (NOT the Render API URL). Required for email buttons, password reset, Stripe return URLs.
# FRONTEND_URL=https://missionledger.fund
# Optional alias: PUBLIC_SITE_URL=https://missionledger.fund

# Optional
ML_EXPOSE_ERROR_DETAILS=false
NODE_ENV=production
